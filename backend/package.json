{
  "name": "planilla-pagos-backend",
  "version": "1.0.0",
  "description": "Backend for planilla de pagos online",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "node scripts/check-syntax.mjs",
    "test": "node --test",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "express-validator": "^7.1.0",
    "pg": "^8.11.5"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^15.15.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.6.2",
    "prisma": "^6.19.3"
  }
}
