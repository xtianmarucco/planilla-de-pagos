generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model clients {
  id         Int          @id @default(autoincrement())
  name       String
  type       client_type
  phone      String?
  address    String?
  is_active  Boolean?     @default(true)
  created_at DateTime?    @default(now()) @db.Timestamp(6)
  payments   payments[]
  sucursales sucursales[]

  @@index([name], map: "idx_clients_name")
}

model sucursales {
  id         Int       @id @default(autoincrement())
  client_id  Int
  name       String
  address    String?
  phone      String?
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now()) @db.Timestamp(6)
  client     clients   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  payments   payments[]

  @@index([client_id], map: "idx_sucursales_client_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payments {
  id             Int            @id @default(autoincrement())
  client_id      Int
  amount         Decimal        @db.Decimal(12, 2)
  payment_date   DateTime       @db.Date
  payment_method payment_method
  status         payment_status @default(PAGADO)
  notes          String?
  created_at     DateTime?      @default(now()) @db.Timestamp(6)
  user_id        Int?
  sucursal_id    Int?
  client         clients        @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           users?         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sucursal       sucursales?    @relation(fields: [sucursal_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([client_id, payment_date], map: "idx_payments_client_date")
  @@index([client_id], map: "idx_payments_client_id")
  @@index([payment_date], map: "idx_payments_payment_date")
  @@index([user_id], map: "idx_payments_user_id")
  @@index([sucursal_id], map: "idx_payments_sucursal_id")
  @@index([status], map: "idx_payments_status")
}

model session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
}

model users {
  id            Int        @id @default(autoincrement())
  email         String     @unique
  password_hash String
  created_at    DateTime?  @default(now()) @db.Timestamp(6)
  name          String     @default("")
  payments      payments[]
}

enum client_type {
  MAYORISTA
  VIABANA
}

enum payment_method {
  EFECTIVO
  TRANSFERENCIA
  CUENTA_CORRIENTE
  OTRO
}

enum payment_status {
  PAGADO
  PENDIENTE
}
